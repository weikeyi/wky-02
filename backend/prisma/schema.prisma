// This is your Prisma schema file.
// Learn more about Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  name      String
  role      String   @default("STUDENT")
  studentId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courseMembers CourseMember[]
  submissions   Submission[]
  reviewsGiven  Review[]         @relation("Reviewer")
  appealsFiled  Appeal[]         @relation("Appellant")
  appealsTAd    Appeal[]         @relation("TAReviewer")
  auditLogs     AuditLog[]
  groupMembers  GroupMember[]
  taughtCourses Course[]         @relation("CourseTeacher")
}

model Course {
  id          String @id @default(uuid())
  name        String
  code        String @unique
  description String?
  teacherId   String
  teacher     User   @relation("CourseTeacher", fields: [teacherId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     CourseMember[]
  assignments Assignment[]
  groups      Group[]
}

model CourseMember {
  id        String   @id @default(uuid())
  courseId  String
  userId    String
  role      String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Group {
  id        String @id @default(uuid())
  courseId  String
  name      String
  createdAt DateTime @default(now())

  course  Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  members GroupMember[]

  @@unique([courseId, name])
}

model GroupMember {
  id       String @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Assignment {
  id                    String  @id @default(uuid())
  courseId              String
  title                 String
  description           String?
  status                String  @default("DRAFT")
  submissionDeadline    DateTime
  reviewDeadline        DateTime
  reviewsPerSubmission  Int     @default(3)
  anonymousReview       Boolean @default(true)
  dropHighestLowest     Boolean @default(true)
  lateDeductionType     String  @default("NONE")
  lateDeductionValue    Float   @default(0)
  lateDeductionMax      Float   @default(100)
  incompleteReviewPenalty Float @default(5)
  maxScore              Float   @default(100)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rubric      RubricCriterion[]
  submissions Submission[]
  appeals     Appeal[]

  @@index([courseId])
}

model RubricCriterion {
  id           String  @id @default(uuid())
  assignmentId String
  name         String
  description  String?
  maxScore     Float
  weight       Float   @default(1)
  order        Int     @default(0)

  assignment Assignment          @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scores     ReviewCriterionScore[]

  @@index([assignmentId])
}

model Submission {
  id             String  @id @default(uuid())
  assignmentId   String
  studentId      String
  content        String?
  attachmentUrl  String?
  status         String  @default("NOT_SUBMITTED")
  submittedAt    DateTime?
  lateMinutes    Int     @default(0)
  finalScore     Float?
  rawScore       Float?
  isLocked       Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])
  reviews    Review[]
  appeals    Appeal[]

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
}

model Review {
  id             String   @id @default(uuid())
  submissionId   String
  reviewerId     String
  status         String   @default("ASSIGNED")
  overallScore   Float?
  overallComment String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submission     Submission          @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer       User                @relation("Reviewer", fields: [reviewerId], references: [id])
  criterionScores ReviewCriterionScore[]

  @@unique([submissionId, reviewerId])
  @@index([submissionId])
  @@index([reviewerId])
}

model ReviewCriterionScore {
  id          String @id @default(uuid())
  reviewId    String
  criterionId String
  score       Float
  comment     String?

  review    Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  criterion RubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([reviewId, criterionId])
}

model Appeal {
  id           String   @id @default(uuid())
  submissionId String
  assignmentId String
  appellantId  String
  status       String   @default("PENDING")
  reason       String
  taReviewerId String?
  taScore      Float?
  taComment    String?
  finalScore   Float?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  appellant  User       @relation("Appellant", fields: [appellantId], references: [id])
  taReviewer User?      @relation("TAReviewer", fields: [taReviewerId], references: [id])

  @@index([submissionId])
  @@index([assignmentId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
